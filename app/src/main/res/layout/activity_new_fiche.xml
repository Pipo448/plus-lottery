<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- En-tèt: retounen / efase tout / pataje / enprime -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="@android:color/transparent"
            android:contentDescription="Retounen"
            android:src="@android:drawable/ic_menu_revert" />

        <ImageButton
            android:id="@+id/btnClearAll"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="4dp"
            android:background="@android:color/transparent"
            android:tint="#DC2626"
            android:contentDescription="Efase tout"
            android:src="@android:drawable/ic_menu_delete" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:tint="#22C55E"
                android:contentDescription="Pataje"
                android:src="@android:drawable/ic_menu_share" />

            <ImageButton
                android:id="@+id/btnPrint"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@android:color/transparent"
                android:tint="#F59E0B"
                android:contentDescription="Enprime"
                android:src="@android:drawable/ic_menu_gallery" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Onglè seksyon: Tiraj / Boul / Kòb -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#808080">

        <View
            android:layout_width="36dp"
            android:layout_height="match_parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Tiraj"
            android:textColor="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Boul"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Kòb"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <!-- ZÒN LIY YO (anwo, ak background vag la, ranpli tout espas ki rete) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_wave_blue">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvFicheLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BORLETTE"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnEditGameLabel"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="4dp"
                    android:background="@android:color/transparent"
                    android:tint="#DC2626"
                    android:contentDescription="Chanje kategori"
                    android:src="@android:drawable/ic_menu_edit" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llLinesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- KONPOZITÈ (anba, fiks): Total + Chwazi Tiraj + kategori + antre manyèl -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Total: 0.00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="LT"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvChwaziTiraj"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="CHWAZI TIRAJ"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnBPaire"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="BPaire"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#3B82F6" />

                <Button
                    android:id="@+id/btnGrap"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Grap"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#F59E0B" />

                <Button
                    android:id="@+id/btnP0"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P0"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP1"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P1"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP2"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P2"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP3"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P3"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP4"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P4"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP5"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P5"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP6"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P6"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP7"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P7"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP8"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P8"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnP9"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="P9"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#22C55E" />

                <Button
                    android:id="@+id/btnMariage"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="MARIAGE"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#F59E0B" />

                <Button
                    android:id="@+id/btnLoto4"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="LOTO4"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#3B82F6" />

                <Button
                    android:id="@+id/btnLoto5"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="LOTO5"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#3B82F6" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="12dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etBoulLa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="Boul la"
                android:inputType="number"
                android:background="@android:drawable/edit_text" />

            <EditText
                android:id="@+id/etMontant"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Pri"
                android:inputType="numberDecimal"
                android:background="@android:drawable/edit_text" />
        </LinearLayout>

        <Button
            android:id="@+id/btnAntre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="ANTRE"
            android:backgroundTint="#3B82F6"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnSoumet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="SOUMÈT FICH LA"
            android:backgroundTint="#DC2626"
            android:textColor="@android:color/white" />
    </LinearLayout>
</LinearLayout>