<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Bouton aksyon anlè (estòb pou kounye a) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/btnKont"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="KONT $"
            android:textColor="@android:color/white" android:backgroundTint="#22C55E" />

        <Button android:id="@+id/btnTiraj"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="TIRAJ"
            android:textColor="@android:color/white" android:backgroundTint="#3B82F6" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/btnBoulKiSoti"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="BOUL KI SOTI"
            android:textColor="@android:color/black" android:backgroundTint="#F59E0B" />

        <Button android:id="@+id/btnMizajou"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="MIZAJOU"
            android:textColor="@android:color/white" android:backgroundTint="#DC2626" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/black"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:padding="8dp"
        android:text="Version : 1.0.0 @PlusGroup" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/llSettingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />
    </ScrollView>
</LinearLayout>
