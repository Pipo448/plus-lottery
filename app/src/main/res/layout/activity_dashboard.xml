<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F1FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Ba wo a: enprimant / mesaj / meni -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnPrinter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:background="@android:color/transparent"
                android:backgroundTint="#22C55E"
                android:contentDescription="Enprimant"
                android:src="@android:drawable/ic_menu_gallery" />

            <ImageButton
                android:id="@+id/btnMail"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_toEndOf="@id/btnPrinter"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:backgroundTint="#3B82F6"
                android:contentDescription="Notifikasyon"
                android:src="@android:drawable/ic_dialog_email" />

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:background="@android:color/transparent"
                android:backgroundTint="#F59E0B"
                android:contentDescription="Meni"
                android:src="@android:drawable/ic_menu_more" />
        </RelativeLayout>

        <!-- Salut + rafrechi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="24dp">

            <TextView
                android:id="@+id/tvSalut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salut"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Rafrechi"
                android:src="@android:drawable/ic_popup_sync" />
        </LinearLayout>

        <!-- Kat balans -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="20dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:textSize="18sp"
                        android:textColor="#888888" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Balance"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCreditVente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Illimité"
                        android:textSize="18sp"
                        android:textColor="#888888" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Crédit de vente"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="16dp">

                <TextView
                    android:id="@+id/tvLimiteGain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Illimité"
                    android:textSize="18sp"
                    android:textColor="#888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Limite gain"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bouton prensipal yo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <Button
                android:id="@+id/btnNouvelFich"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="NOUVÈL FICH"
                android:textColor="@android:color/white"
                android:backgroundTint="#22C55E" />

            <Button
                android:id="@+id/btnChacheFich"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="CHACHE FICH"
                android:textColor="@android:color/white"
                android:backgroundTint="#3B82F6" />

            <Button
                android:id="@+id/btnFichMwenYo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="FICH MWEN YO"
                android:textColor="@android:color/white"
                android:backgroundTint="#F59E0B" />

            <Button
                android:id="@+id/btnRapo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="RAPÒ"
                android:textColor="@android:color/white"
                android:backgroundTint="#DC2626" />
        </LinearLayout>

    </LinearLayout>

    <!-- Ba anba a: Bolèt / Paramèt -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#3B82F6">

        <LinearLayout
            android:id="@+id/tabBolet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bolèt"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabParamet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paramèt"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
