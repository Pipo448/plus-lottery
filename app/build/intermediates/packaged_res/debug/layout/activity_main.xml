<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#EAF2FB"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Byenveni 👋"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1B0E52"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ekran vann tikè ap vini pita isit la."
        android:textSize="14sp"
        android:textColor="#475569"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvPrinterStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enprimant: ap konekte..."
        android:textSize="13sp"
        android:textColor="#334155"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnChoosePrinter"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="#F59E0B"
        android:text="Chwazi Enprimant Bluetooth"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnTestPrint"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="#3B82F6"
        android:text="Tès Enprimant"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="#DC2626"
        android:text="Dekonekte"
        android:textColor="#FFFFFF" />

</LinearLayout>
