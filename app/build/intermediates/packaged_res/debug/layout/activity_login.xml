<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF2FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Plus"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#1B0E52" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="POS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:textColor="#3B82F6"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input"
            android:hint="Idantifyan"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:autofillHints="username" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_input"
            android:hint="Modpas"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:autofillHints="password" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#DC2626"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            tools:text="Erè egzanp"
            xmlns:tools="http://schemas.android.com/tools" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#3B82F6"
            android:text="KONEKTE"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="DEVICE ID"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#1B0E52" />

        <TextView
            android:id="@+id/tvDeviceIdValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#DC2626"
            android:fontFamily="monospace"
            tools:text="3218bb5334cec2d5"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Version 1.0.0 @PlusGroup"
            android:textSize="12sp"
            android:textColor="#64748B" />

    </LinearLayout>
</ScrollView>
